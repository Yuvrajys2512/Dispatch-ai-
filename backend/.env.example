# Provider mode: "mock" (no credentials needed) or "real" (Phase 7)
PROVIDER_MODE=mock

# Server (8000/5432/6379 are intentionally avoided — used by a neighbouring project)
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# CORS — frontend dev origin
CORS_ORIGINS=http://localhost:5173

# Data layer (used from Phase 1; match docker-compose.yml)
DATABASE_URL=postgresql+psycopg://dispatch:dispatch@localhost:5433/dispatch
REDIS_URL=redis://localhost:6380/0

# --- Real provider config (Phase 7 only — leave blank for mock) ---
# NEVER commit real keys. Set these only in your local .env (gitignored), then
# flip PROVIDER_MODE=real to swap mocks for Exotel + Sarvam + a real LLM.

# Exotel telephony (Indian inbound number → webhook → bidirectional media WS)
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_API_BASE=https://api.exotel.com
# Number the AI bridges to on human handoff (control-room desk line)
EXOTEL_OPERATOR_NUMBER=
# Publicly-reachable base URL Exotel calls back (ngrok/cloudflared tunnel or a
# deployed host). Exotel points the inbound number's "Voice" applet here.
EXOTEL_WEBHOOK_BASE_URL=
EXOTEL_RECORD=true

# Sarvam ASR/TTS (Hindi/Indic speech). hi-IN = answer + transcribe in Hindi.
SARVAM_API_KEY=
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_LANGUAGE=hi-IN
SARVAM_ASR_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=meera

# Real LLM (witness only — the agent owns severity). Default: Claude Haiku 4.5.
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
# Optional: override the Anthropic base URL (proxy/gateway). Blank = default.
LLM_BASE_URL=

# Resilience: timeout + circuit breaker before falling back to mock/handoff
PROVIDER_TIMEOUT_MS=1200
BREAKER_FAILURE_THRESHOLD=3
BREAKER_RESET_SECONDS=30
